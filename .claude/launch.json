{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH pnpm --filter client dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH pnpm --filter server dev"],
      "port": 4000,
      "autoPort": false
    }
  ]
}
