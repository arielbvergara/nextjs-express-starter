# ============================================
# Application
# ============================================
NODE_ENV=development

# ============================================
# Client (Next.js)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ============================================
# Server (Express)
# ============================================
PORT=4000
CLIENT_URL=http://localhost:3000

# ============================================
# Google Service Account
# ============================================
# Create a service account in Google Cloud Console and grant it access
# to the Calendar, Sheets, and Drive resources you want to read.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# Google API Scopes (pre-configured)
# ============================================
# These are set in server/src/config/google.ts
# - https://www.googleapis.com/auth/calendar.readonly
# - https://www.googleapis.com/auth/spreadsheets.readonly
# - https://www.googleapis.com/auth/drive.readonly

# ============================================
# Gmail API (OAuth2 user credentials)
# ============================================
# Used for sending transactional emails via the Gmail API.
# Unlike Calendar/Sheets, Gmail with a personal account requires OAuth2
# user credentials (not a service account).
#
# How to obtain:
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (type: Web application)
# 3. Add https://developers.google.com/oauthplayground as an Authorized Redirect URI
# 4. Visit https://developers.google.com/oauthplayground
#    → Settings → Use your own OAuth credentials → enter Client ID & Secret
# 5. Authorize scope: https://www.googleapis.com/auth/gmail.send
# 6. Exchange authorization code for tokens → copy the Refresh Token
GMAIL_CLIENT_ID=your-oauth2-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-oauth2-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_SENDER_EMAIL=your@gmail.com