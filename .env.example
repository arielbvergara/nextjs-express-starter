# ============================================
# Application
# ============================================
NODE_ENV=development

# ============================================
# Client (Next.js)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ============================================
# Server (Express)
# ============================================
PORT=4000
CLIENT_URL=http://localhost:3000

# ============================================
# Google Service Account
# ============================================
# Create a service account in Google Cloud Console and grant it access
# to the Calendar, Sheets, and Drive resources you want to read.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# Google API Scopes (pre-configured)
# ============================================
# These are set in server/src/config/google.ts
# - https://www.googleapis.com/auth/calendar.readonly
# - https://www.googleapis.com/auth/spreadsheets.readonly
# - https://www.googleapis.com/auth/drive.readonly