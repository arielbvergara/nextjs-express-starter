#!/usr/bin/env sh
# Husky pre-push: run tests + build
if [ "${HUSKY:-1}" = "0" ]; then
  exit 0
fi

# Ensure package managers installed via Homebrew or common paths are available
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:$PATH"

echo "🚀 Running pre-push checks..."

echo "🧪 Running tests..."
pnpm test || exit 1

echo "📦 Building..."
pnpm build || exit 1

echo "✅ Pre-push checks passed!"
